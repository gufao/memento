{
  "name": "memento",
  "version": "2.1.0",
  "author": "Memento Team",
  "description": "YouTube video downloader built with Tauri, React, HeroUI, and yt-dlp",
  "private": true,
  "type": "module",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "dev": "cargo tauri dev",
    "build": "cargo tauri build",
    "build:mac": "cargo tauri build --target universal-apple-darwin",
    "build:win": "cargo tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "cargo tauri build --target x86_64-unknown-linux-gnu",
    "preview": "vite preview"
  },
  "dependencies": {
    "@bro-sdk/web": "^0.1.1",
    "@heroui/react": "^2.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.0.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
